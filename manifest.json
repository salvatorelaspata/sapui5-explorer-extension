{
  "manifest_version": 3,
  "name": "SAPUI5 Explorer",
  "description": "Analyze SAPUI5/OpenUI5 applications: components, models, bindings, views, controllers, logs and runtime info.",
  "version": "1.0",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SAPUI5 Explorer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
